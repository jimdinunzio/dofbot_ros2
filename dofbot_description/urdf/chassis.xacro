<?xml version="1.0"?>
<!--
  Path B collision geometry: the mobile-robot chassis the DOFBOT arm is bolted
  in front of, plus a virtual floor.

  dofbot.urdf covers only the arm and its mounting plate, so on its own MoveIt
  will plan the arm straight back (-x) into the robot body, and straight down
  through the table. These two fixed links give it the missing solids. Both are
  collision primitives, not meshes: cheap to check, and the real shapes are a
  cylinder and a plane anyway.

  Frame (base_link): +x forward (pick zone), -x toward the chassis, +z up,
  origin at the arm mounting plate (its underside is z=0).

  The floor is attached to base_link, not to the world, on purpose: the robot is
  mobile, and the work surface is always the same fixed distance below the arm's
  mounting plate. Hanging it off base_link keeps that true as the robot drives.

  Defaults are the values measured on the real robot and validated at runtime
  through the chassis_collision node (which this replaces).
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:macro name="dofbot_chassis" params="
      parent:=base_link
      radius:=0.165
      height:=0.335
      back_offset:=0.265
      z_bottom:=0.003
      floor_z_top:=-0.015
      floor_thickness:=0.005
      floor_x_front:=0.35
      floor_x_back:=-0.5
      floor_half_width:=0.35">

    <material name="chassis_orange">
      <color rgba="0.90 0.45 0.10 0.55"/>
    </material>
    <material name="floor_brown">
      <color rgba="0.40 0.26 0.13 0.35"/>
    </material>

    <!-- Robot body: a z-axis cylinder behind the arm. URDF cylinders are
         centred on the link origin, so the joint places the centre. -->
    <link name="chassis_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="${radius}" length="${height}"/>
        </geometry>
        <material name="chassis_orange"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="${radius}" length="${height}"/>
        </geometry>
      </collision>
    </link>

    <joint name="chassis_joint" type="fixed">
      <parent link="${parent}"/>
      <child link="chassis_link"/>
      <origin xyz="${-back_offset} 0 ${z_bottom + height / 2.0}" rpy="0 0 0"/>
    </joint>

    <!-- Virtual floor / work surface. -->
    <link name="floor_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <box size="${floor_x_front - floor_x_back}
                     ${2.0 * floor_half_width}
                     ${floor_thickness}"/>
        </geometry>
        <material name="floor_brown"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <box size="${floor_x_front - floor_x_back}
                     ${2.0 * floor_half_width}
                     ${floor_thickness}"/>
        </geometry>
      </collision>
    </link>

    <joint name="floor_joint" type="fixed">
      <parent link="${parent}"/>
      <child link="floor_link"/>
      <origin xyz="${(floor_x_front + floor_x_back) / 2.0} 0
                   ${floor_z_top - floor_thickness / 2.0}" rpy="0 0 0"/>
    </joint>

  </xacro:macro>
</robot>
